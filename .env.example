# Shipeedo OAuth — copy to .env and fill in real values
# Never commit .env

CLIENT_ID=
CLIENT_SECRET=
AUTH_ENDPOINT=

# Usually required for OAuth callback (confirm with Shipeedo client setup)
# REDIRECT_URI=http://localhost:3000/auth/callback

# If Shipeedo exposes a separate token URL (common for OAuth2)
# TOKEN_ENDPOINT=
