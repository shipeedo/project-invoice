# Shipeedo OAuth — copy to .env and fill in real values
# Never commit .env

CLIENT_ID=
CLIENT_SECRET=

# Issuer URL — the app discovers authorization, token, userinfo, JWKS, etc.
# via GET {OIDC_ISSUER}/.well-known/openid-configuration
OIDC_ISSUER=

# Required for OAuth callback (set to match your Shipeedo client registration)
# REDIRECT_URI=http://localhost:3000/auth/callback
