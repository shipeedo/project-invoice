# Copy to .env for local dev — see docs/environment-setup.md for full setup
# Never commit .env

CLIENT_ID=project-invoice
CLIENT_SECRET=

# Issuer URL — the app discovers authorization, token, userinfo, JWKS, etc.
# via GET {OIDC_ISSUER}/.well-known/openid-configuration
OIDC_ISSUER=https://auth.shipeedo.com

# Must match a redirect URI registered on the OAuth client
REDIRECT_URI=http://localhost:3000/api/auth/callback/shipeedo

# Auth.js session encryption — generate with: openssl rand -base64 32
AUTH_SECRET=

# Use mock credentials login when CLIENT_SECRET is unset (local pilot only)
# AUTH_MOCK=true

# Tenant API base URL (development only) — used by the admin Users section to
# list tenant users via /api/core/user/getusers. Leave unset in production:
# the load balancer routes /api on the app's own origin to the tenant service.
# TENANT_API_URL=https://tenant.shipeedo.com

# SQLite database for local development
DATABASE_URL="file:./dev.db"

# Platform Azure app — powers "Connect Office 365" for all tenancies (Phase 1b)
# Customer tenant ID and mailbox are configured in the UI, not here
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# MS_REDIRECT_URI=http://localhost:3000/api/o365/callback

# Optional secret for scheduled mailbox polling (POST /api/cron/o365/poll)
# Background polling runs every 5 minutes via instrumentation.ts unless disabled:
# DISABLE_BACKGROUND_O365_POLL=true
# CRON_SECRET=

# AI — invoice extraction (header, line items, etc.)
#
# The AI connector (Vercel AI Gateway or an OpenAI-compatible endpoint), model,
# and API key are now configured in the UI under Admin → Connections → AI
# Extraction, and stored in the database. The API key is encrypted at rest using
# AUTH_SECRET, so no AI_* environment variables are needed here.

# Web Push (browser notifications) — generate with: npx web-push generate-vapid-keys
# When unset, push delivery is skipped; the in-app notification bell still works.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com
