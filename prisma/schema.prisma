generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  APPROVER
  USER
}

enum InvoiceStatus {
  RECEIVED
  PROCESSING
  PENDING_APPROVAL
  APPROVED
  READY_FOR_PAYMENT
  REJECTED
  NEEDS_REVIEW
}

enum InvoiceSourceType {
  UPLOAD
  EMAIL
}

enum RoutingRuleType {
  SENDER_EMAIL
  AMOUNT_THRESHOLD
  PARSE_FAILURE
  DEFAULT
}

model Organization {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  users        User[]
  invoices     Invoice[]
  suppliers    Supplier[]
  routingRules RoutingRule[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model User {
  id               String        @id @default(cuid())
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email            String        @unique
  name             String?
  role             UserRole      @default(APPROVER)
  assignedInvoices Invoice[]     @relation("AssignedApprover")
  routingRules     RoutingRule[]
  auditEvents      AuditEvent[]
  creditDrafts     CreditDraft[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([organizationId])
}

model Invoice {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status           InvoiceStatus     @default(RECEIVED)
  sourceType       InvoiceSourceType @default(UPLOAD)
  originalFileName String?
  filePath         String?
  fileMimeType     String?
  vendorName       String?
  vendorEmail      String?
  invoiceNumber    String?
  invoiceDate      DateTime?
  totalAmount      Float?
  currency         String?           @default("AUD")
  lineItems        String?
  extractionRaw    String?
  parseError       String?
  assignedToId     String?
  assignedTo       User?             @relation("AssignedApprover", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes            Note[]
  auditEvents      AuditEvent[]
  creditDrafts     CreditDraft[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([organizationId, status])
  @@index([assignedToId])
}

model Note {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  userId    String?
  content   String
  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model RoutingRule {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  priority       Int
  type           RoutingRuleType
  condition      String
  approverId     String?
  approver       User?           @relation(fields: [approverId], references: [id], onDelete: SetNull)
  isDefault      Boolean         @default(false)
  enabled        Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, priority])
}

model Supplier {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  emailAddresses String       @default("[]")
  emailDomains   String       @default("[]")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model AuditEvent {
  id        String   @id @default(cuid())
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model CreditDraft {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  subject     String
  message     String
  attachments String   @default("[]")
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}
